{
  "redirects": [
    {
      "source": "/",
      "destination": "/outputs/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/outputs/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/outputs/verified-puzzles.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
